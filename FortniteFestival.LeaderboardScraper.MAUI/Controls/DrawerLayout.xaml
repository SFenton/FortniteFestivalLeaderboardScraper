<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FortniteFestival.LeaderboardScraper.MAUI.Controls.DrawerLayout"
             SizeChanged="OnSizeChanged">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Header with hamburger (hidden in compact mode) -->
    <Grid x:Name="HeaderBar" Grid.Row="0" HeightRequest="52" Padding="12,8" ColumnDefinitions="Auto,*">
      <Label x:Name="HamburgerButton" Text="☰" FontSize="24" FontFamily="NotoSansBold" TextColor="White" VerticalOptions="Center">
        <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnHamburgerTapped" /></Label.GestureRecognizers>
      </Label>
    </Grid>
    <!-- Page content slot -->
    <Grid Grid.Row="1" x:Name="ContentHost" />
    
    <!-- Bottom Nav Bar (visible in compact mode only) -->
    <Border x:Name="BottomNavBar" Grid.Row="2" IsVisible="False" BackgroundColor="#4B0F63" Padding="0" HeightRequest="60">
      <Grid ColumnDefinitions="*,*,*,*">
        <!-- Songs -->
        <Grid x:Name="BottomNavSongs" Grid.Column="0" Padding="8">
          <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSongsTapped" /></Grid.GestureRecognizers>
          <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
            <Label Text="🎵" FontSize="20" HorizontalOptions="Center" />
            <Label Text="Songs" FontSize="10" TextColor="White" HorizontalOptions="Center" />
          </VerticalStackLayout>
        </Grid>
        <!-- Suggestions -->
        <Grid x:Name="BottomNavSuggestions" Grid.Column="1" Padding="8" IsVisible="False">
          <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSuggestionsTapped" /></Grid.GestureRecognizers>
          <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
            <Label Text="💡" FontSize="20" HorizontalOptions="Center" />
            <Label Text="Tips" FontSize="10" TextColor="White" HorizontalOptions="Center" />
          </VerticalStackLayout>
        </Grid>
        <!-- Statistics -->
        <Grid x:Name="BottomNavStatistics" Grid.Column="2" Padding="8">
          <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavStatisticsTapped" /></Grid.GestureRecognizers>
          <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
            <Label Text="📊" FontSize="20" HorizontalOptions="Center" />
            <Label Text="Stats" FontSize="10" TextColor="White" HorizontalOptions="Center" />
          </VerticalStackLayout>
        </Grid>
        <!-- Settings -->
        <Grid x:Name="BottomNavSettings" Grid.Column="3" Padding="8">
          <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSettingsTapped" /></Grid.GestureRecognizers>
          <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
            <Label Text="⚙️" FontSize="20" HorizontalOptions="Center" />
            <Label Text="Settings" FontSize="10" TextColor="White" HorizontalOptions="Center" />
          </VerticalStackLayout>
        </Grid>
      </Grid>
    </Border>
    
    <!-- Drawer overlay (for non-compact mode) -->
    <Grid x:Name="NavDrawerOverlay" Grid.RowSpan="3" IsVisible="False" BackgroundColor="#00000055">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border x:Name="DrawerPanel" BackgroundColor="#4B0F63" StrokeShape="RoundRectangle 0" Padding="16,20,16,28" WidthRequest="260">
        <VerticalStackLayout Spacing="18">
          <Grid ColumnDefinitions="*,Auto" HeightRequest="24">
            <Label />
            <Label Text="✕" TextColor="White" FontSize="18" VerticalOptions="Center">
              <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnCloseDrawerTapped" /></Label.GestureRecognizers>
            </Label>
          </Grid>
          <Grid x:Name="SuggestionsNavItem" ColumnDefinitions="Auto,*" HeightRequest="40" IsVisible="False">
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSuggestionsTapped" /></Grid.GestureRecognizers>
            <Label Text="💡" FontSize="20" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="Suggestions" FontFamily="NotoSansBold" TextColor="White" VerticalOptions="Center" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*" HeightRequest="40">
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSongsTapped" /></Grid.GestureRecognizers>
            <Label Text="🎵" FontSize="20" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="Songs" FontFamily="NotoSansBold" TextColor="White" VerticalOptions="Center" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*" HeightRequest="40">
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavStatisticsTapped" /></Grid.GestureRecognizers>
            <Label Text="📊" FontSize="20" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="Statistics" FontFamily="NotoSansBold" TextColor="White" VerticalOptions="Center" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*" HeightRequest="40">
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnNavSettingsTapped" /></Grid.GestureRecognizers>
            <Label Text="⚙️" FontSize="20" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="Settings" FontFamily="NotoSansBold" TextColor="White" VerticalOptions="Center" />
          </Grid>
        </VerticalStackLayout>
      </Border>
      <Grid Grid.Column="1">
        <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnCloseDrawerTapped" /></Grid.GestureRecognizers>
      </Grid>
    </Grid>
  </Grid>
</ContentView>
