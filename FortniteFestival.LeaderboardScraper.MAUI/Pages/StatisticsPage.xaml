<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FortniteFestival.LeaderboardScraper.MAUI.Pages.StatisticsPage"
             Title="Statistics"
             BackgroundColor="{StaticResource PageBackground}">
  <Shell.BackButtonBehavior>
    <BackButtonBehavior IsVisible="False" IsEnabled="False" />
  </Shell.BackButtonBehavior>
  <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>
  <Grid Padding="{StaticResource PagePadding}">
    <Label x:Name="PageTitle" Text="Statistics" FontFamily="NotoSansBold" FontAttributes="Bold" FontSize="28" TextColor="White" VerticalOptions="Start" Margin="0,0,0,12" />
    <ScrollView x:Name="MainScroll" Margin="0,44,0,0" IsVisible="False">
      <VerticalStackLayout x:Name="StatsStack" Spacing="16" Padding="0,0,0,12" />
    </ScrollView>
    <VerticalStackLayout x:Name="EmptyState" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False">
      <Label Text="No Statistics Available" FontFamily="NotoSansBold" FontSize="20" HorizontalTextAlignment="Center" TextColor="White" />
      <Label Text="Sync your scores to see your Fortnite Festival stats." FontSize="13" Opacity="0.85" HorizontalTextAlignment="Center" TextColor="White" />
    </VerticalStackLayout>
    <ActivityIndicator x:Name="LoadingSpinner" IsRunning="True" IsVisible="True" WidthRequest="56" HeightRequest="56" Color="White" HorizontalOptions="Center" VerticalOptions="Center" />
  </Grid>
</ContentPage>
