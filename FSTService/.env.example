# FSTService local development secrets
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
#
# Variable names use __ (double underscore) as the section separator,
# which ASP.NET Core maps to the corresponding appsettings.json path.

# Epic Games OAuth (from Epic Developer Portal → Product Settings → Clients)
EpicOAuth__ClientId=your-epic-client-id
EpicOAuth__ClientSecret=your-epic-client-secret

# Override redirect URI for local dev (use your local FSTService URL)
# EpicOAuth__RedirectUri=http://localhost:8080/api/auth/epiccallback

# JWT signing key (at least 256 bits / 32 bytes, base64 or hex)
# Jwt__Secret=generate-a-random-256-bit-secret

# Token encryption key for stored Epic tokens
# EpicOAuth__TokenEncryptionKey=generate-a-random-256-bit-key
