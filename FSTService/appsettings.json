{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "FSTService": "Debug",
      "FSTService.Api.ApiKeyAuthHandler": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    }
  },
  "Scraper": {
    "ScrapeInterval": "04:00:00",
    "WebRegistrationRetentionDays": 7,
    "RankHistorySnapshotMaxDegreeOfParallelism": 1,
    "DegreeOfParallelism": 512,
    "QueryLead": true,
    "QueryDrums": true,
    "QueryVocals": true,
    "QueryBass": true,
    "QueryProLead": true,
    "QueryProBass": true,
    "DataDirectory": "data",
    "DeviceAuthPath": "data/device-auth.json",
    "CHOptPath": "tools/CHOpt",
    "EnablePathGeneration": true,
    "PathGenerationParallelism": 4,
    "SongMachineDop": 32,
    "LeaderboardWriteMode": "DiskSpool",
    "OnlineWriteBatchPages": 64,
    "OnlineDbWriterConcurrency": 2,
    "BandExtractionParallelism": 8,
    "BandMembershipRebuildBatchSize": 2000,
    "ScrapePassTimeoutMinutes": 0,
    "EnableBandScraping": true,
    "ProxyUrls": [],
    "ControlUrls": []
  },
  "Features": {
    "Leaderboards": false,
    "Difficulty": false,
    "PlayerBands": false,
    "ExperimentalRanks": false,
    "ComputeRankingDeltas": false,
    "UseRankingDeltaTiers": true,
    "WriteLegacyLiveLeaderboardDuringScrape": false
  },

  "ImprovementNotifications": {
    "Enabled": false,
    "Scope": "registered",
    "IncludePlayers": true,
    "IncludeBands": true,
    "IncludeSongEvents": true,
    "IncludeRankings": true,
    "PruneExpired": true,
    "RefreshSoloProjection": true,
    "RefreshAllSoloScopesWhenNoImpactedScopes": false,
    "CommandTimeoutSeconds": 0,
    "SoloProjectionCommandTimeoutSeconds": 0,
    "FailScrapeOnError": false
  },

  "BandRankHistory": {
    "Mode": "Background",
    "UseLatestState": true,
    "UseNarrowHistory": true,
    "UseWideHistoryCompatibilityWrite": true,
    "ApiReadSource": "NarrowWithWideFallback",
    "ChunkSize": 250000,
    "MaxParallelChunks": 1,
    "CommandTimeoutSeconds": 0,
    "RetentionDays": 365,
    "SynchronousCommitOff": false,
    "CoalesceSameDaySnapshots": true,
    "MaxCatchupAgeHours": 24
  },

  "BandTeamRankings": {
    "WriteMode": "Monolithic",
    "CommandTimeoutSeconds": 0,
    "AnalyzeStagingTable": false,
    "DisableSynchronousCommit": true,
    "OverlapRankHistorySnapshotsWithBandRankings": false
  },

  "DatabaseMaintenance": {
    "SkipCleanupWhenPressureDetected": true,
    "RankHistoryCleanupBatchSize": 5000,
    "RankHistoryCleanupMaxBatches": 1,
    "BandRankHistoryCleanupBatchSize": 5000,
    "BandRankHistoryCleanupMaxBatches": 1,
    "CleanupCommandTimeoutSeconds": 120,
    "ServiceLevelRetentionMaintenanceEnabled": true,
    "SnapshotRetentionRewriteEnabled": false,
    "SnapshotRetentionReportOnlyWhenDisabled": true,
    "SnapshotRetentionRollbackCompletedSnapshotsToKeep": 1,
    "SnapshotRetentionMaxPartitionsPerRun": 1,
    "SnapshotRetentionMinimumEstimatedPurgeBytes": 1073741824,
    "SnapshotRetentionMaximumEstimatedRetainedBytes": 0,
    "SnapshotRetentionFreeSpacePath": null,
    "SnapshotRetentionMinimumFreeBytes": 0,
    "MetadataTtlCleanupEnabled": true,
    "MetadataRetentionDays": 180,
    "MetadataCleanupBatchSize": 5000,
    "MetadataCleanupMaxBatches": 1,
    "CompletedScrapeLogRowsToKeep": 100,
    "LongRunningMaintenanceSeconds": 30,
    "WatchedTableDeadTupleThreshold": 10000000,
    "WatchedTables": [
      "leaderboard_entries_snapshot",
      "band_team_rank_history",
      "band_team_rank_history_points",
      "band_team_ranking_stats_history",
      "band_song_team_rankings",
      "composite_rank_history",
      "rank_history"
    ]
  },

  "BackgroundJobs": {
    "StopBeforeNextScrapeMinutes": 5,
    "MaxGracefulStopSeconds": 30,
    "PauseBestEffortOnScrapeStart": true,
    "MaxDbConnections": 1
  },

  "Api": {
    "ApiKey": "dfc3d5b232a24c458db366650a1961de",
    "AllowedOrigins": [ "http://localhost:3000" ]
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },

  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=fstservice;Username=fst;Password=fst_dev;Minimum Pool Size=2;Maximum Pool Size=15;Connection Idle Lifetime=30;Connection Pruning Interval=10;Command Timeout=0"
  }
}
