{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "paths": {
      "@festival/core": ["./packages/core/src"],
      "@festival/core/*": ["./packages/core/src/*"],
      "@festival/ui": ["./packages/ui/src"],
      "@festival/ui/*": ["./packages/ui/src/*"],
      "@festival/contexts": ["./packages/contexts/src"],
      "@festival/contexts/*": ["./packages/contexts/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods", "packages/*/dist"]
}
